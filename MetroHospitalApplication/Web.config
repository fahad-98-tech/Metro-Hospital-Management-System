<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<!-- Database Connection -->
	<connectionStrings>
		<add name="MetroHospitalDB" connectionString="Data Source=FAHAD;Initial Catalog=MetroHospitalDB;Integrated Security=True" providerName="System.Data.SqlClient" />
	</connectionStrings>



	<system.web>
		<compilation debug="true" targetFramework="4.7.2" />
		<httpRuntime targetFramework="4.7.2" />
	</system.web>
</configuration>